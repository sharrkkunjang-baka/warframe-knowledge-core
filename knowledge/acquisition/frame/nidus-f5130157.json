      "categoryRefs": []
    },
    "prerequisites": [
      "完成《混沌之扰》（The Glast Gambit）主线任务",
      "解锁厄里斯（Eris）星球节点 Oestrus"
    ],
    "methodRefs": [
      "gameplay.enemy-and-mission-drops",
