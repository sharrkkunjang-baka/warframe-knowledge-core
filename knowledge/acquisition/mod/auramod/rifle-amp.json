          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rifle Amp",
                  "pageId": 87673,
                  "revisionId": 2784038,
                  "section": "Notes",
                  "excerpt": "As stated on the mod description Rifle Amp increases rifle damage, but it also affects bows, sniper rifles and launchers ( Ogris , Penta , etc.). Shotguns do not benefit from this mod, as it has its own aura counterpart ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rifle Amp",
                  "pageId": 87673,
                  "revisionId": 2784038,
                  "section": "Notes",
                  "excerpt": "Rifle Amp adds to the base damage as Serration and Heavy Caliber do."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rifle Amp",
                  "pageId": 87673,
                  "revisionId": 2784038,
                  "section": "Notes",
                  "excerpt": "Rifle Damage = Base Damage × (1 + Serration + Heavy Caliber + Rifle Amp)"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rifle Amp",
                  "pageId": 87673,
                  "revisionId": 2784038,
                  "section": "Notes",
                  "excerpt": "Therefore, the actual bonus from a maxed rifle amp is only +(27 ÷ (1 + Damage Bonus ))%, where Damage Bonus is the damage bonus from Serration and Heavy Caliber as a decimal fraction. That's +12.3% for a 7/10 Serration, +10.2% for a maxed Serration, and +6.3% for a maxed Serration and maxed Heavy Caliber."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rifle Amp",
                  "pageId": 87673,
                  "revisionId": 2784038,
                  "section": "Notes",
                  "excerpt": "Assuming a maxed Serration and no Heavy Caliber is equipped on the rifle, without damage type modifiers, against an armored enemy, it will deal more damage with Corrosive Projection than with Rifle Amp if the target's armor is higher than 134. For a damage type that has a +75% bonus against the target's armor type, Corrosive Projection surpasses Rifle Amp if armor is higher than 536."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rifle Amp",
                  "pageId": 87673,
                  "revisionId": 2784038,
                  "section": "Notes",
                  "excerpt": "Can be stacked with other members using this aura, for a total of +108% additive damage bonus."
                }
              }
