              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Siphon",
                  "pageId": 87576,
                  "revisionId": 2720660,
                  "section": "Notes",
                  "excerpt": "Channeled abilities that drain energy over time, such as Immolation , Sound Quake , and Renewal will completely prevent energy generation for as long as they are active. Abilities with variable energy drain such as Artemis Bow , Pacify & Provoke and Desecrate do not interrupt energy siphon."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Siphon",
                  "pageId": 87576,
                  "revisionId": 2720660,
                  "section": "Notes",
                  "excerpt": "The Sortie \"Energy Reduction\" condition also reduces the rate of energy regeneration."
                }
              },
