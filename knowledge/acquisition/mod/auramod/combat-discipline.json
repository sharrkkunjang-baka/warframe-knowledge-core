          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "The aura bearer health loss and ally health gain are separately triggered, as follows:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "When the aura bearer kills an enemy, only the aura bearer loses health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "When an ally kills an enemy, only that ally gains health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Companion kills count as user kills."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Does not heal Companions."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Multiple instances of Combat Discipline in a squad stack in an unusual way: the formula for health gain for each squad member with the mod equipped is A+B+C-D, where A, B and C are the health gain values of ally instances of Combat Discipline, and D is the health loss value of the aura-bearer's own instance of the mod (each squad member has a different variable because this formula assumes that different players may choose to keep their Combat Discipline at different ranks) . Using this formula, if all 4 players in a squad equip max rank copies of Combat Discipline, each player will heal +50 health per kill (+20 from each ally and -10 for the player's own copy). All the damage/heal happens on the same instance, making it not do any damage to the player doing kills."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "The health loss is considered damage taken which bypasses shields , as such:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "The aura bearer can be downed with this mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Losing 1 health from a rank 0 aura will kill the aura bearer on 2 health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Damage Reduction affects the amount of health lost per kill."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Invulnerability fully prevents the health loss."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Allows Arcane Enhancements that trigger on damage (i.e. Arcane Avenger ) to be maintained with regular kills."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Triggers Vex Armor 's Fury buff."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Will be redirected by Parasitic Link and Link ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Overshields make Hildryn completely immune to this damage, due to her passive."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "However, it does not trigger Rage or Hunter Adrenaline 's energy conversion."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "It does trigger Health Conversion , causing a stack to be lost."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Triggers the explosion effect of Nourish ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Combat Discipline",
                  "pageId": 1449742,
                  "revisionId": 2793388,
                  "section": "Notes",
                  "excerpt": "Damage is taken from Overguard first if present - effects that trigger on damage will still function but effects that explicitly require health to be lost will not"
                }
              }
