            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "This is an Assault Rifle -exclusive mod. It does not work with Bows /Crossbows or Sniper Rifles ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "For any non-integer magazine values the magazine size is simply rounded to the nearest whole number. For example, a Braton modded with a max rank Tainted Mag will have a calculated magazine size of 45 × (1 + 66%) = 74.7 , which will simply round to 75 ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "Note that due to the way Reload Speed is calculated, reduced reload speed has a more substantial effect on reload time than increased reload speed."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "For example, Braton has a default reload speed of 2.0 seconds;"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "With +30% reload speed from a rank 5 Fast Hands , the reload time would be 1.54 seconds, or a 23% reduction of reload time."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "With -30% reload speed from a rank 9 Tainted Mag, the reload time would be 2.85 seconds, or a ~29% increase of reload time."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "The two mods can be used together to counteract the reload speed penalty."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "Stacks with Magazine Warp and Wildfire for a total of 116% magazine capacity ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "Stacks with Primed Magazine Warp (55%) and Wildfire (+20%) for a total of 141% magazine capacity ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "Despite being for assault rifles, Tainted Mag will work on launchers like the Tonkor as well as semi-auto rifles like the Latron ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tainted Mag",
                  "pageId": 233450,
                  "revisionId": 2731598,
                  "section": "Notes",
                  "excerpt": "For Battery Weapons such as the Flux Rifle or Fulmin , the reload time penalty only affects the reload delay and not the ammo regeneration rate. In other words, this mod will only increase the time before reloading starts."
                }
              }
