            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blind Rage",
                  "pageId": 233733,
                  "revisionId": 2774240,
                  "section": "Notes",
                  "excerpt": "At rank 5, Blind Rage will give 24% more Ability Strength than Intensify for the same cost, but abilities will use more energy. At this rank, a fully-ranked Streamline alone is sufficient to negate the downside. It is, however, still weaker than just using Intensify + Augur Secrets as you are also benefitting from the shield recovery and drain less."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blind Rage",
                  "pageId": 233733,
                  "revisionId": 2774240,
                  "section": "Notes",
                  "excerpt": "Fleeting Expertise can be used to negate a maxed Blind Rage 's downside at the cost of Ability Duration."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blind Rage",
                  "pageId": 233733,
                  "revisionId": 2774240,
                  "section": "Notes",
                  "excerpt": "In most cases, however, it is better to either invest in ability duration instead, or just not to use Blind Rage . Ability Efficiency has increasing returns, meaning it's better and better the more you invest in. On the other hand, negative Efficiency is hard to make up for directly, and can be covered more efficiently with additional duration instead ( Blind Rage + Streamline is less energy efficient than Blind Rage + Continuity )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blind Rage",
                  "pageId": 233733,
                  "revisionId": 2774240,
                  "section": "Notes",
                  "excerpt": "Can be stacked with Intensify , Transient Fortitude , Augur Secrets and Power Drift to provide a total of +223% Ability Strength ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blind Rage",
                  "pageId": 233733,
                  "revisionId": 2774240,
                  "section": "Notes",
                  "excerpt": "You may also stack it with Energy Conversion to get a total of 273% after collecting an Energy Orb ."
                }
              }
