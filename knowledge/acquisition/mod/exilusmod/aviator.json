            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Aviator",
                  "pageId": 361168,
                  "revisionId": 2789518,
                  "section": "Notes",
                  "excerpt": "Airborne damage reduction affects Titania 's Razorwing , Hildryn 's Aegis Storm , Jade 's Glory on High , Styanax 's Final Stand , and Oraxia while wall latching with her Silken Stride active."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Aviator",
                  "pageId": 361168,
                  "revisionId": 2789518,
                  "section": "Notes",
                  "excerpt": "Can be used with Agility Drift to grant a 1 - [ (1 - 0.4 ) * (1 - 0.12 ) ] = 47.2% damage reduction while airborne. In addition, can be used with Agility Drift and Aerodynamic to grant 1 - [ (1 - 0.4 ) * (1 - 0.12 ) * (1 - 0.24 ) ] = 59.872% damage reduction while airborne. Further, can be used with Agility Drift , Aerodynamic , and the full Boreal's Set bonus to grant 1 - [ (1 - 0.4 ) * (1 - 0.12 ) * (1 - 0.24 ) * (1 - 0.6) ] = 83.9488% damage reduction while airborne."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Aviator",
                  "pageId": 361168,
                  "revisionId": 2789518,
                  "section": "Notes",
                  "excerpt": "Can be used in conjunction with rolling in the air for an even greater damage reduction."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Aviator",
                  "pageId": 361168,
                  "revisionId": 2789518,
                  "section": "Notes",
                  "excerpt": "This mod cannot be used simultaneously with Ironclad Flight on Titania ."
                }
              }
