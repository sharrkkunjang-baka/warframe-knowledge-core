          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Handspring",
                  "pageId": 36910,
                  "revisionId": 2692484,
                  "section": "Notes",
                  "excerpt": "Works with anything that would knock a player down, and additionally shortens the stagger animation from self-stagger weapons (does not affect the flinch animation that occurs at the edge of the explosion.)"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Handspring",
                  "pageId": 36910,
                  "revisionId": 2692484,
                  "section": "Notes",
                  "excerpt": "This is very useful when you are swarmed and a Shockwave MOA , Bursa , Shield Lancer or Ancient Healer / Ancient Disruptor knocks you down. It's also useful against bosses that have a stomp attack, such as Jackal , Hyena Pack , and Ambulas ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Handspring",
                  "pageId": 36910,
                  "revisionId": 2692484,
                  "section": "Notes",
                  "excerpt": "This mod is particularly valuable when attempting to solo a mission as knockdowns and the long period of helplessness they cause are one of the most common causes of death when you have no teammates to back you up."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Handspring",
                  "pageId": 36910,
                  "revisionId": 2692484,
                  "section": "Notes",
                  "excerpt": "Maxed (and other ranks) Handspring speeds up the recovery animation by changing it to a flip-up animation."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Handspring",
                  "pageId": 36910,
                  "revisionId": 2692484,
                  "section": "Notes",
                  "excerpt": "The flip-up animation is similar, if not identical, to that of MOA 's kick-up."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Handspring",
                  "pageId": 36910,
                  "revisionId": 2692484,
                  "section": "Notes",
                  "excerpt": "Unranked Handspring speeds up the recovery animation without changing the animation (like Constitution )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Handspring",
                  "pageId": 36910,
                  "revisionId": 2692484,
                  "section": "Notes",
                  "excerpt": "If stacked with ranked Constitution , the recovery animation may change to the flip-up animation if the recovery time is short enough."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
