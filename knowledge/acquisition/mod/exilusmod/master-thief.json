          "evidence": [],
          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Master Thief",
                  "pageId": 54584,
                  "revisionId": 2587868,
                  "section": "Notes",
                  "excerpt": "Upon approaching a locked locker (with a red light) the mod automatically tries to make it unlockable. If successful, the locker will shimmer with a blue light, accompanied by a brief hissing sound, after which the locker's lights will turn to green or white (depending on the faction), signifying that it can now be opened."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Master Thief",
                  "pageId": 54584,
                  "revisionId": 2587868,
                  "section": "Notes",
                  "excerpt": "If an unsuccessful attempt at unlocking a locker happens, the locker's lights will be turned off, meaning players can't unlock it anymore."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Master Thief",
                  "pageId": 54584,
                  "revisionId": 2587868,
                  "section": "Notes",
                  "excerpt": "Players can also use this mod to open MOA Cabinet Spawners , but if it fails there will be no visual changes to the cabinet."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Master Thief",
                  "pageId": 54584,
                  "revisionId": 2587868,
                  "section": "Notes",
                  "excerpt": "The effects of this mod do not stack when multiple players in a party have it equipped. If a locker fails to unlock when Master Thief is applied to it, it will not unlock if other players with the mod equipped also try on the same locker."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Master Thief",
                  "pageId": 54584,
                  "revisionId": 2587868,
                  "section": "Notes",
                  "excerpt": "It also seems it doesn't stack with Scavenge either, as lockers that don't unlock from the mod will be mostly ignored by Kubrows and Kavats ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Master Thief",
                  "pageId": 54584,
                  "revisionId": 2587868,
                  "section": "Notes",
                  "excerpt": "Since Scavenge is 90% successful, as compared to this Master Thief's 40%, it is advisable to use a pet with Scavenge to open lockers instead."
                }
              }
            ],
