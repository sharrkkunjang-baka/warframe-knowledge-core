          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thief's Wit",
                  "pageId": 19065,
                  "revisionId": 2728761,
                  "section": "Notes",
                  "excerpt": "Thief's Wit (and similar mods) will mark Cephalon Fragments in range on the map with a unique blue diamond icon. Somachord and Frame Fighter fragments are likewise marked with their own icons."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thief's Wit",
                  "pageId": 19065,
                  "revisionId": 2728761,
                  "section": "Notes",
                  "excerpt": "When in a mission with other players, resources picked up by another player aside from yourself will not remove them from the mini-map. They will disappear only when you pick it up. The radar is not shared with any other player, so you will need to guide teammates using waypoints, etc. to resources."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thief's Wit",
                  "pageId": 19065,
                  "revisionId": 2728761,
                  "section": "Notes",
                  "excerpt": "Due to the random generation of every map, and also the Containers within them, you will be able to see Containers that you are unable to get to, especially at Rank 4 and above, due to them being in a location that may appear near but is only accessible from a different area of the map."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thief's Wit",
                  "pageId": 19065,
                  "revisionId": 2728761,
                  "section": "Notes",
                  "excerpt": "Originally, the mod granted only 5 meters of vision per rank. The mod was buffed to 7 meters per rank around Update 12.1 (2014-02-13)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thief's Wit",
                  "pageId": 19065,
                  "revisionId": 2728761,
                  "section": "Notes",
                  "excerpt": "As of Update: The Silver Grove (2016-08-19), Loot Detector, Animal Instinct and Thief's Wit do not highlight mods through walls."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thief's Wit",
                  "pageId": 19065,
                  "revisionId": 2728761,
                  "section": "Notes",
                  "excerpt": "Thief's Wit, along with Loot Detector and Animal Instinct will display Resource Caches in select Sabotage and Exterminate missions. However, due to the fact that Resource Caches uses the same icon as a normal container, it's advised to go and destroy every container that you see on the minimap."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thief's Wit",
                  "pageId": 19065,
                  "revisionId": 2728761,
                  "section": "Notes",
                  "excerpt": "Does not work on Index points."
                }
              }
            ],
