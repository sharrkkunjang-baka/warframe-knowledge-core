          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "The shockwave is activated by the speed of landing rounded down to the speed threshold:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "16 m/s is the required threshold for damage; 32 m/s earns 2.0x damage, 48 m/s earns 3.0x, etc."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "Impact radius is scaled without rounding: 1.0x at 16 m/s, 1.5x at 24 m/s, 2.0x at 32 m/s, etc."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "Despite the mod describing \"heavy landings,\" the shockwave will trigger even if the hard landing animation is avoided, such as by sliding during landing."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "However, immunity to hard landings from Kavat's Grace or Valkyr 's passive makes it impossible to activate Heavy Impact."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "Some melee weapons will hit the ground first when using a jump attack, meaning Heavy Impact will not activate."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "The blast color is affected by your Warframe's energy color."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "Directional melee and wall running can activate Heavy Impact independent of speed of landing."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Heavy Impact",
                  "pageId": 112615,
                  "revisionId": 2701839,
                  "section": "Notes",
                  "excerpt": "Rhino 's passive ability matches Heavy Impact at max rank. Equipping Heavy Impact on Rhino will further increase the effectiveness."
                }
              }
