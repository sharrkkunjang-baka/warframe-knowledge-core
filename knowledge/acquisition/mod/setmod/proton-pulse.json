            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Proton Pulse",
                  "pageId": 1421999,
                  "revisionId": 2783318,
                  "section": "Notes",
                  "excerpt": "Despite the mod's description mentioning Wall Dashing, the effect is currently activated after Wall Latching. It is not required to end the wall latch by wall dashing (although this also triggers the effect); simply cancelling the latch is enough to trigger it."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Proton Pulse",
                  "pageId": 1421999,
                  "revisionId": 2783318,
                  "section": "Notes",
                  "excerpt": "The effect lasts until a Bullet Jump is used or the player touches the ground."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Proton Pulse",
                  "pageId": 1421999,
                  "revisionId": 2783318,
                  "section": "Notes",
                  "excerpt": "Affects Rolling , Sidespring , Backspring and Double Jump despite not mentioning it in the description, which is effectively all that affects Parkour Velocity ."
                }
              },
