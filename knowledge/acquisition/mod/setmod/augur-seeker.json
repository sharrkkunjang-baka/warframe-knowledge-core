              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Augur Seeker",
                  "pageId": 1214987,
                  "revisionId": 2722112,
                  "section": "Notes",
                  "excerpt": "Augur Seeker 's effects are only visible on Status Effects with an associated duration, either increasing the duration of the associated debuff ( Puncture , Cold , Magnetic , Corrosive , Radiation , and Viral ), or the number of ticks associated with DoT effects ( Slash , Toxin , Gas , and Heat )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Augur Seeker",
                  "pageId": 1214987,
                  "revisionId": 2722112,
                  "section": "Notes",
                  "excerpt": "This mod will not affect the duration of crowd control effects generated by Status Effects (staggers from Impact , the panic duration of Heat , and the stun animation caused by Electricity )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Augur Seeker",
                  "pageId": 1214987,
                  "revisionId": 2722112,
                  "section": "Notes",
                  "excerpt": "Increased Status Duration will slow down the Armor Strip effect of Heat . For example, with +100% status duration, the armor strip will occur every second instead of every half second. As a result, the full 50% armor strip will only be achieved after 4 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Augur Seeker",
                  "pageId": 1214987,
                  "revisionId": 2722112,
                  "section": "Notes",
                  "excerpt": "Status Effects from the radial blasts of Syndicate Weapon Augments and Syndicate Weapons are not affected by this mod."
                }
              }
