          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "As Strain Consume 's health increase is percentage-based, Warframes with high Health pools (such as Inaros ) will see a greater benefit from this mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "Assuming all Strain Set mods are fully ranked and equipped, a Warframe can increase up to 32 % of their maximum Health should the Maggots die within range."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "However, the maximum Health increase does not have an upper limit to account for varying number of Maggot corpses. Meaning one could delay their collection of corpses to further increase their health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "But Corpses on the ground expire eventually and each buff instance has its individual duration, meaning the realistic upper limit is a 64 % max health increase"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "Same applies to the passive health regeneration, for a maximum recovery of 32 Health /s as opposed to 16 Health /s."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "The Health increase scales multiplicatively with other sources of increased Max Health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "A rank 30 Inaros Prime equipped with a Rank 10 Vitality along side a Strain Consume with its full set bonus will have (2415 + (2415 × 100%)) × 1.32 = 6,375.6 Maximum Health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Strain Consume",
                  "pageId": 1376482,
                  "revisionId": 2722649,
                  "section": "Notes",
                  "excerpt": "Does not affect flat Maximum Health bonuses from sources such as Azure Archon Shard , Tauforged Azure Archon Shard , Arcane Blessing and Arcane Intention ,"
                }
              }
            ],
