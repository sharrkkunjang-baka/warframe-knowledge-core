          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hunter Synergy",
                  "pageId": 1235678,
                  "revisionId": 2738023,
                  "section": "Notes",
                  "excerpt": "The mod additively increases the Kubrow 's or Kavat 's critical chance by a percentage of the total Critical Chance on the player's primary weapon."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hunter Synergy",
                  "pageId": 1235678,
                  "revisionId": 2738023,
                  "section": "Notes",
                  "excerpt": "For example, equipping a Soma with 75% Critical Chance will add 22.5% Critical Chance to the companion."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hunter Synergy",
                  "pageId": 1235678,
                  "revisionId": 2738023,
                  "section": "Notes",
                  "excerpt": "This amount is affected by Point Strike and other critical chance-enhancing mods for primary weapons, including temporary buffs like Galvanized Scope ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hunter Synergy",
                  "pageId": 1235678,
                  "revisionId": 2738023,
                  "section": "Notes",
                  "excerpt": "This bonus stacks after other mods have been applied."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hunter Synergy",
                  "pageId": 1235678,
                  "revisionId": 2738023,
                  "section": "Notes",
                  "excerpt": "If you have a Primary Weapon with 100% Critical Chance, a Kubrow with 10% base critical chance with both Bite and Hunter Synergy equipped will have: 10% (Base) + 10% x 330% (Bite) + 30% (Hunter Synergy) = 73%."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hunter Synergy",
                  "pageId": 1235678,
                  "revisionId": 2738023,
                  "section": "Notes",
                  "excerpt": "For weapons with Incarnon forms, switching to Incarnon form will increase the Critical Chance bonus for the purpose of Tenacious Bond , but does not actually increase the Critical Chance of the Claws."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hunter Synergy",
                  "pageId": 1235678,
                  "revisionId": 2738023,
                  "section": "Notes",
                  "excerpt": "For example, Strun Prime without an Evolution IV bonus and modded with Critical Deceleration has a Critical Chance of 72% outside of Incarnon form and 144% in it. A Kubrow with 10% base Critical Chance will have 31.6% Critical Chance with the Strun Prime equipped, but switching to Incarnon form will activate Tenacious Bond's bonus while the Kubrow's Critical Chance remains 31.6%."
                }
              }
            ],
