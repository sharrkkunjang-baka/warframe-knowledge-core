          "evidence": [],
          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Proton Snap 's Status Chance bonus is additive rather than multiplicative."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Total Status Chance = Base Status Chance × (1 + Normal Status Chance Mods) + Proton Snap"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "For example, a Galatine with a max rank Melee Prowess , Proton Snap , and Weeping Wounds at a 2.0x combo mulitplier will have a 20% × (1 + 90% + 40% × (2.0 - 1) ) + 50% = 96% status chance."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Must be equipped to Exalted Weapons to apply to them."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Fully applies to pseudo-exalted melee skills including Landslide , Whipclaw , Shattered Lash , and Slash Dash ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Since the bonus is additive, this mod gives the latter two the ability to inflict status effects when they normally cannot, however the Status Chance bonus doesn't extend to detonating Mass Vitrify ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "In rare cases where stances multiply modded status chance on attacks, such as Iron Phoenix 's first hit of Wings and Beak , they will not multiply Proton Snap 's bonus."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Total Status Chance = Base Status Chance × (1 + Normal Status Chance Mods) × (1 + Stance Status Chance Bonus) + Proton Snap"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "The Toxin will combine with other elements according to Proton Snap 's mod placement. Because this only applies while Proton Snap is active, it is possible to change elements in the middle of play by activating and deactivating the effect."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "If equipped alongside a Toxin mod or on a weapon with innate Toxin damage, Proton Snap will not allow for changing of elements, and will instead work based on where the first Toxin mod is placed (including Proton Snap )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Proton Snap does not extend its effects to weapons or abilities it is not equipped on."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Proton Snap",
                  "pageId": 1422005,
                  "revisionId": 2722617,
                  "section": "Notes",
                  "excerpt": "Cannot be equipped on Melee Robotic Weapons ( Deconstructor ( Prime ), Akaten , Batoten , and Lacerten )."
                }
              }
            ],
