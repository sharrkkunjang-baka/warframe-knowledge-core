            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Synth Charge",
                  "pageId": 1362593,
                  "revisionId": 2791096,
                  "section": "Notes",
                  "excerpt": "Magazine requirement is based on the base Magazine Capacity of a gun. If the magazine is increased above 6 on a weapon that has below 6, it will still not be usable on that gun. However, if a gun has a magazine above 6 and it is reduced below that, the mod will still function."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Synth Charge",
                  "pageId": 1362593,
                  "revisionId": 2791096,
                  "section": "Notes",
                  "excerpt": "Cannot be equipped on Exalted Weapons , and has no effect on Continuous Weapons even if they meet the magazine requirements."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Synth Charge",
                  "pageId": 1362593,
                  "revisionId": 2791096,
                  "section": "Notes",
                  "excerpt": "Does not have an effect on any Incarnon fire modes, whether on the last shot in their magazine or if activated with one bullet left in the primary mode's magazine."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Synth Charge",
                  "pageId": 1362593,
                  "revisionId": 2791096,
                  "section": "Notes",
                  "excerpt": "Damage stacks multiplicatively with Hornet Strike , and any area damage the weapon may have is also affected."
                }
              },
