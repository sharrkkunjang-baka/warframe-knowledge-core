            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "Mecha Pulse 's effect applies based on who killed the marked enemy, with companions passing the effect onto their owner. Accordingly, if an ally or a specter kills the marked enemy, they will get the Armor bonus instead of you."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "The Operator can also get and benefit from the armor bonus."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "Bonus is additive to the bonus from Steel Fiber ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "Multiple stacks can be active at once, with each stack having its own timer."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "The range of this mod is based on the killing ally's location, and not the location of the marked enemy. Despite this, it will always grant a minimum of +60% Armor , even if there are no enemies within its range."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "Due to this, despite the similar range to the set effect, it cannot be used to estimate how many enemies were affected unless you specifically were directly adjacent to the marked enemy when you killed it."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "If your Kubrow is equipped with Link Fiber , the bonus armor will benefit it as well."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "Must have a Kubrow companion equipped to make use of the set bonus."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "The marked enemy will display a blue Mecha Set icon above its head."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Mecha Pulse",
                  "pageId": 1362619,
                  "revisionId": 2722522,
                  "section": "Notes",
                  "excerpt": "Does not multiply the bonus armor granted by Azure Archon Shards ."
                }
              }
