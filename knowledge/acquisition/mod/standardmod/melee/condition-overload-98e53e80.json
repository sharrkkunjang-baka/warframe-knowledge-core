          "evidence": [],
          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "This damage does not apply to Slams and Heavy Slams ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "There is no limit to the number of status effects the mod is affected by."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "The bonus damage gained by this mod stacks additively with other damage mods like Pressure Point and Spoiled Strike to increase your melee damage (including proc damage like Slash ). Total damage is calculated as such:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Total Damage = Base Damage × [1 + Damage Mods + (Condition Overload Multiplier × n)] × (1 + Elemental Mods) (with n being the number of unique status effects currently affecting the enemy)"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "The bonus damage of a new status effect is not applied to the hit which inflicted it (or its proc damage) – only subsequent strikes are amplified."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Gunblades' pellets hit consecutively and therefore can be amplified by other pellets of the same shot."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Status procs may originate from any source, including primary and secondary weapons, Warframe abilities, companions, other players, or the environment."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Impact , Puncture , Slash , Cold , Electricity , Heat , Toxin , Blast , Corrosive , Gas , Magnetic , Radiation , Viral , Void and Tau procs all count for the damage bonus. Additionally:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Lifted from Melee Heavy Attacks also counts."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Microwave from Nukor and Kuva Nukor is a unique invisible status. Microwave procs have infinite duration."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Knockdown while does not incur a visible status, still counts towards the damage bonus."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Note that conditions or abilities that prevent knockdowns (e.g. Bastille ) will prevent it from increasing damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Since Lifted and knockdown will cancel out each other, the maximum number of status effects that can be applied to an enemy is 16."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Condition Overload",
                  "pageId": 1090045,
                  "revisionId": 2722113,
                  "section": "Notes",
                  "excerpt": "Radial status effects ( Blast , Electricity and Gas ) still get the bonus damage from this mod as it is part of Modded Base Damage , and it is calculated based on the initial target, not individually per enemy hit."
                }
              }
            ],
