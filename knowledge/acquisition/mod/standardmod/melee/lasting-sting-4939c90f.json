          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lasting Sting",
                  "pageId": 571600,
                  "revisionId": 2621086,
                  "section": "Notes",
                  "excerpt": "The mod's effects are only visible on Status Effects with an associated duration, either increasing the duration of the associated debuff ( Corrosive , Puncture , Cold , Magnetic , Radiation , and Viral ), or the number of ticks associated with DoT effects ( Slash , Toxin , Gas , and Heat )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lasting Sting",
                  "pageId": 571600,
                  "revisionId": 2621086,
                  "section": "Notes",
                  "excerpt": "This mod will not affect the duration of crowd control effects generated by Status Effects (staggers from Impact , the panic duration of Heat , and the stun animation caused by Electricity )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lasting Sting",
                  "pageId": 571600,
                  "revisionId": 2621086,
                  "section": "Notes",
                  "excerpt": "However, it does affect the duration of the freeze effect applied by Cold after reaching 10 stacks."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lasting Sting",
                  "pageId": 571600,
                  "revisionId": 2621086,
                  "section": "Notes",
                  "excerpt": "Increased Status Duration will slow down the Armor Strip effect of Heat . For example, with +100% status duration, the armor strip will occur every second instead of every half second. As a result, the full 50% armor strip will only be achieved after 4 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lasting Sting",
                  "pageId": 571600,
                  "revisionId": 2621086,
                  "section": "Notes",
                  "excerpt": "Status Effects from the radial blasts of Syndicate Weapon Augments and Syndicate Weapons are not affected by this mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lasting Sting",
                  "pageId": 571600,
                  "revisionId": 2621086,
                  "section": "Notes",
                  "excerpt": "Due to status duration always rounding down, there is no difference in performance between a 9th rank and 10th rank version of this mod without other sources of status duration (such as Saryn or Lavos)."
                }
              }
            ],
