              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Smite Grineer",
                  "pageId": 112417,
                  "revisionId": 2687253,
                  "section": "Notes",
                  "excerpt": "Despite being listed as a multiplier, it will stack additively with other sources of Damage to Grineer."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Smite Grineer",
                  "pageId": 112417,
                  "revisionId": 2687253,
                  "section": "Notes",
                  "excerpt": "For example, if you had a Riven Mod with x0.5 Damage to Grineer and a max rank Smite Grineer with x1.3 Damage to Grineer, you would have a 1 - 0.5 + 0.3 = x0.8 multiplier for damage against Grineer with both mods equipped."
                }
              }
