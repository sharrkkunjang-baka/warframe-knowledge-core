          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "Added in Update 8.0 (2013-05-23)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "Upon striking an enemy, all of the stored energy will be discharged. The strike can be a normal strike, slide attack or a heavy attack."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "The stored energy will not discharge when striking terrain or a cargo container."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "Be careful not to hit a recently killed enemy, as it may discharge on swing contact."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "If the attack hits multiple targets, the bonus damage is only applied to a single target. Additionally, if the attack hits the same target multiple times, the bonus damage is only applied to one hit."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "Due to both the ratio and storage capacity scaling, the bonus damage maxes out after spending a total of 100 energy at any rank."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "A weapon charged with energy via Energy Channel will glow the energy color of the particular weapon, with pulses of energy washing over it regularly."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "Streamline affects energy stored by Energy Channel; it uses the adjusted ability cost."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "The bonus damage is added after the critical hit multiplier."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "The glowing effect will not apply to the Prova , nor will any other visual effects."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "The damage done by Elemental Mods (i.e. Molten Impact ) is amplified by this Mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "The damage is not amplified by damage increasing Mods (i.e. Pressure Point , Killing Blow )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Energy Channel",
                  "pageId": 56240,
                  "revisionId": 2587555,
                  "section": "Notes",
                  "excerpt": "Before Update 13.0 (2014-04-09), this mod was called Melee Channel."
                }
              }
