            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Heals the user the stated amount for each status effect currently afflicting the target. For example, with a Rank 10 Healing Return (+11), attacking an enemy afflicted with Slash , Puncture , and Toxin statuses will heal 11×3 health, a total of 33 health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Healing Return can be used to much avail on certain low status weapons as well:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "High Impact damage weapons like Heliocor or Shaku will trigger Healing return with every attack, regardless of an Impact proc actually occurring."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Certain weapons (such as dual daggers equipped with Gnashing Payara , or Gram even without a stance) trigger a \"flinch\" effect on enemies with every hit, which triggers Healing Return."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Note that many Stances have at least one combo that has a force proc."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Multiple instances of the same status effect (e.g. 4 individual Slash DoTs) will not increase the healing given."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Both the Redeemer and Sarpa 's charge attacks will heal the user. Each individual pellet triggers an instance of healing (e.g., if 5 pellets hit an enemy afflicted with a status effect, the healing amount will be 5×11 = 55HP). Because both gunblades' charged attacks are guaranteed to proc an Impact effect, they are guaranteed to heal the user if the Healing Return mod is equipped."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "If equipped on the Deconstructor ( Prime ), this mod will allow Helios ( Prime ) to heal itself provided its target is suffering status effects."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Does not provide any healing if your attack, despite proccing a Status Effect on the attack (for example, with 100% status chance ), kills the target instantly on the first attack."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "The AoE damage from the explosion of Exodia Contagion 's projectile will not trigger the healing effect of this mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "The healing effect is triggered for each enemy hit by an attack independently, so attacking a squad of enemies all with Status effects with a long Reach weapon can give significant healing over time."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Does work with Hound weapons like the Akaten ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Healing Return",
                  "pageId": 1090050,
                  "revisionId": 2685510,
                  "section": "Notes",
                  "excerpt": "Does not trigger Archon Intensify when used on exalted weapons such as Excalibur 's Exalted Blade ."
                }
              }
