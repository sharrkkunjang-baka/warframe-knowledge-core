              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Guardian Derision",
                  "pageId": 1090048,
                  "revisionId": 2783786,
                  "section": "Notes",
                  "excerpt": "The taunt is high priority and will steal aggro from other aggro-increasing abilities."
                }
              },
