          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blood Rush",
                  "pageId": 907907,
                  "revisionId": 2767558,
                  "section": "Notes",
                  "excerpt": "Blood Rush multiplies critical chance based on the Melee Combo Counter tier increase."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blood Rush",
                  "pageId": 907907,
                  "revisionId": 2767558,
                  "section": "Notes",
                  "excerpt": "Without a Combo Counter, Blood Rush provides no bonus to critical chance. At 2x, it increases critical chance by 0.40 × (2 - 1) = 40% and at 3x, it increases critical chance by 0.40 × (3 - 1) = 80% . At the standard max Combo Counter of 12x, it increases critical chance by 440%."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blood Rush",
                  "pageId": 907907,
                  "revisionId": 2767558,
                  "section": "Notes",
                  "excerpt": "Pairs very well with Body Count , Drifting Contact , Gladiator Rush , or The Primary Dexterity & Secondary Dexterity arcanes which allow players to keep the Combo Counter up more consistently."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blood Rush",
                  "pageId": 907907,
                  "revisionId": 2767558,
                  "section": "Notes",
                  "excerpt": "Highly recommended to use the Focus/Naramon school. The Power Spike passive prevents total combo loss, decaying the counter by only 5 hits at a time. This makes it an exceptionally powerful school for any blood rush build."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Blood Rush",
                  "pageId": 907907,
                  "revisionId": 2767558,
                  "section": "Notes",
                  "excerpt": "Since thrown attacks from Glaive weapons are affected by the Combo Counter, they will also receive any bonus from Blood Rush."
                }
              }
            ],
