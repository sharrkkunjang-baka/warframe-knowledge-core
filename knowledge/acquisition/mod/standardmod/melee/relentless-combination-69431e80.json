          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "At maximum rank, Relentless Combination increases the Melee Combo Counter by +1 for every Slash proc inflicted per enemy. A combo hit is applied for each application of Slash and additional +1 hits thereafter for every tick of Bleed damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "If the enemy dies while under the Bleed proc or Bleed runs out, you will stop gaining additional hits from that enemy."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "Only Slash procs caused by melee weapons count; Slash procs from primary or secondary weapons, Warframe abilities (including abilities that are affected by melee weapon mods or the Combo Counter, such as Shattered Lash or Blade Storm ), or Rending Turn will not increase the Combo Counter."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "Exalted Blade , Diwata , Iron Staff , Valkyr Talons , and Garuda Talons can equip the mod and benefit from it."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "Slash procs from Exalted Blade 's energy waves, including ones cast from Slash Dash while Exalted Blade is active, add hits to the combo counter."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "Slash procs from thrown Glaives also add hits, even though the combo counter does not interact with Glaives."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "Note that several melee weapons are incapable of inflicting Bleed due to not dealing any Slash damage, but can still equip the mod for no benefits. This can be partially rectified by using Stance combos with forced Slash procs."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Relentless Combination",
                  "pageId": 1090054,
                  "revisionId": 2611222,
                  "section": "Notes",
                  "excerpt": "Benefits from \"Additional Combo Count Chance\" mods such as True Punishment and Quickening ."
                }
              }
            ],
