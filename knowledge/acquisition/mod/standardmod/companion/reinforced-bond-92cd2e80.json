                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Reinforced Bond",
                  "pageId": 1581002,
                  "revisionId": 2742091,
                  "section": "Notes",
                  "excerpt": "Bows and Battery Weapons cannot generate overshield."
                }
              },
              {
