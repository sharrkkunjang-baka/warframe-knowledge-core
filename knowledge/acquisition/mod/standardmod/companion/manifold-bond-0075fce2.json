          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Companion Ability cooldown reduction can be triggered by the player or companion killing enemies affected by 3 or more unique Status Effects."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "When a Companion uses a Precept that hits an enemy, all Damage Types , modded or innate, are inflicted as Status Effects on the enemy at one stack."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "For example, a MOA is equipped with Shockwave Actuators and a Deth Machine Rifle modded for Gas and Cold . When it uses Shockwave Actuators, all enemies hit by the shockwave are inflicted with one stack of Gas , Cold , Impact , Puncture , and Slash ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Only whether an element is on the weapon is taken into account, not weighting or status duration. Mods such as Lasting Sting have no effect."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Elements generated via Momentous Bond will also apply to Companion Precepts."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Requires Precepts to deal damage or apply status in order to trigger the companion weapon's status effects - this excludes Precepts that affect enemies in other ways, such as Cordon , while Precepts with delayed damage such as Fatal Attraction or Anti-Grav Grenade will likewise only trigger status application on the damage instance."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Not all damaging Precepts mention dealing any damaging hits in their descriptions; these include Whiplash Mine , Shockwave Actuators , and Repo Audit ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Precepts that apply innate status without dealing damage include Coolant Leak and Electro Pulse ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Applied status effects that can deal damage are not affected by mods or the base damage of the companion weapon. They will deal 1 damage per damage tick."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Due to the Heat Inherit mechanic, when utilizing Heat based weaponry, it is not recommended to mod Heat on your companion weapon as to avoid lowering your Heat DoT output if your companion precepts inflict Heat before you."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "This may be beneficial when using Contagious Bond because if the first heat proc is from a companion all subsequent heat procs will be counted as damage from that companion."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "However, despite only adding Heat damage of weapon hits, the increased Heat from Fired Up can be Heat Inherited from applied procs from abilities."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Faction Damage Mods are still applied once if applied on a target with a heat proc from Manifold Bond"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Works with every hit of Eximus auras copied by Null Audit ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "The cooldown reduction of companion abilities does not include:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "The cooldown on cloaking on Ghost from Shade ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Manifold Bond",
                  "pageId": 1580999,
                  "revisionId": 2784643,
                  "section": "Notes",
                  "excerpt": "Manifold Bond will trigger on Wisp Reservoirs Shock Mote."
                }
              }
