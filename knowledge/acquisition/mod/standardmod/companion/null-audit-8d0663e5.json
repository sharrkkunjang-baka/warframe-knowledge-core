                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "The Hound will locate the nearest Eximus enemy and attack it, generating a transparent bubble effect around the attacked unit, copying their unique abilities to the Hound and stripping Overguard. The Hound can only have one aura at a time. Eximus Behaviors are as follows:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Arson/Caustic Eximus gives the Hound the ability to use a fire blast to knock back enemies."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Arctic/Frozen Eximus gives the Hound a radius that slightly slows down enemies while periodically generating a Snow Globe for its own protection. The globe blocks enemy fire, while Tenno gunfire can pass through unhindered."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Shock/Bio-Electric Eximus will allow the Hound to fire off three shock orbs every 10 seconds that seek and rotate around enemies. The damage is non-existent on the Hound, compared to an enemy using this ability."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Venomous Eximus gives the Hound Toxin procs on attacks and a 3m toxin cloud surrounding it. The damage is negligible."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Guardian Eximus gives the Hound and Tenno a Damage Reduction buff, but will not inherit the rotating shields."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Blitz Eximus gives the Hound the ability to use the shockwave every 10 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Sanguine/Leech Eximus gives the Hound life steal on all attacks. Additionally, the Hound will generate the same sapping zones that the Eximus units can, which appear to do scaling damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Energy Leech/Parasitic Eximus gives the Hound Magnetic procs on attacks, providing 3 energy per second over 3 seconds to Tenno within 25 meters. The Hound will also generate the same sapping fields associated with this Eximus, inflicting 2 Magnetic procs on any enemies in the area and restoring energy to nearby players."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Jade Light Eximus will target nearby enemies with homing satellite lasers, dealing increasing Heat damage the longer the targeted enemy stays under it."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Null Audit",
                  "pageId": 1549179,
                  "revisionId": 2696138,
                  "section": "Notes",
                  "excerpt": "Almost all abilities will inherit the Hound's chosen energy colors, allowing players to distinguish allied Eximus abilities. The Jade Light is a partial exception: while the beam's source will inherit the Hound's energy color, the beam will largely remain green."
                }
              }
