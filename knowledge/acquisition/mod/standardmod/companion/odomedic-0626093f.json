          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "Although the description implies that it heals 40 health over 4 seconds, it instead heals 40 health per second for 4 seconds, totaling for 160 health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "A second/third stack is gained after traversing the distance listed on the mod once again."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "After gaining 3 stacks, any more distance will only reset the timer for the healing."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "Every stack gained resets the timer and adds one stack to the counter."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "Loses one stack at a time, refreshing the timer of remaining stacks."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "The user also does not need to maintain constant contact with a wall to meet the healing requirements, simply performing a single wall-jump and remaining airborne long enough to cover 3m will provide one stack from the mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "The total distance covered must be horizontal."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "Aim-gliding will interrupt the total distance covered, preventing stacks from being gained."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "During the Bullet Jump animation, the horizontal distance will not be counted after a wall hop. The distance before and after the animation, however, will be counted."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Odomedic",
                  "pageId": 1424304,
                  "revisionId": 2696092,
                  "section": "Notes",
                  "excerpt": "A good strategy to stack the mod quickly and efficiently is to hop away from the wall, double jump, and perform a roll. This will usually give 2-3 stacks."
                }
              }
            ],
