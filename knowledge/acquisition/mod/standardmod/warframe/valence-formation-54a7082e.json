          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Upon casting an ability with an imbued element, grants a 200% Elemental Damage buff of the imbued element to all of Lavos's weapons for 20 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "No buff will be granted when casting an ability with no element infused, or when casting Helminth abilities."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Only one elemental bonus can be active at a time. Casting another ability with a mixed element will replace it and refresh the duration."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Bonus Elemental Damage will be added parallel to the weapon’s Elemental Damage, meaning it will NOT combine with elements on the weapon."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Damage bonus is additive to elemental damage bonuses like Heated Charge ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Due to how status DoT damage is calculated, a Valence Formation buff for Heat , Electricity , Toxin , or Gas will also add 200% DoT damage to all procs of that specific element."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Blast damage is exempt, as its proc damage does not scale with elemental damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "The bonus is additive to elemental damage bonuses like Heated Charge , and multiplicative to Faction Damage bonuses like Bane of Grineer and Status Damage bonuses like Rifle Elementalist ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "The 200% bonus DoT damage also applies to matching status procs from all of Lavos's abilities, including Helminth abilities."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "For example, a heat Valence Formation buff will triple the DoT damage from his Catalyze , heat-imbued Ophidian Bite , subsumed Thermal Sunder , etc. Note that the initial ability damage will be unaffected, only the resulting DoT will be increased."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Valence Formation buff is applied immediately on cast (before the ability finishes its animation), allowing the ability cast that grants the buff to also benefit from the bonus DoT damage (if applicable)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "As the damage of the Gas status effect does not scale with equipped Heat and Toxin mods, Valence formation is one of the few ways to increase its damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Unlike most other buffs in the game, Valence Formation cannot be negated by nullifying bubble or enemy abilities, nor by jumping Out Of Bounds ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Valence Formation is a Universal Weapon Bonus , meaning it not only applies to weapons but also to certain \"weapon coded\" abilities. Of the subsumable abilities, Valence Formation can give its elemental damage and guaranteed proc to Airburst (direct hits), Breach Surge , Null Star , Pyrotechnics , and Shuriken ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "Valence Formation is one of the only buffs in the game that affects the AoE explosion of Vile Discharge , though it will only add the guaranteed status effect, not the elemental damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Valence Formation",
                  "pageId": 1583859,
                  "revisionId": 2738699,
                  "section": "Notes",
                  "excerpt": "However, the proc (except for Radiation ) will affect Lavos if he is within range, unless he has Valence Block active to negate it."
                }
              }
            ],
