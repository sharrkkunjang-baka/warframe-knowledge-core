              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "Damage taken while Quick Thinking is in effect does not count as taking Health damage; as such, Rage and Hunter Adrenaline do not convert incoming damage into energy, and Vex Armor and Vexing Retaliation do not trigger their effects."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "While under the effects of Quick Thinking, strong hits will cause the Warframe to stagger. Be wary, as repeated strong hits can effectively stun-lock you in place until you die. Weak hits will not induce this effect."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "Pain Threshold drastically reduces the stagger duration, allowing one to avoid being stun-locked."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "A max rank Primed Sure Footed will not affect the stagger."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "Quick Thinking has the lowest priority of almost all death prevention effects, such as Nidus ' passive or Phoenix Renewal . Quick Thinking will only start draining energy after all other means of preventing lethal damage are exhausted."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "Wukong 's passive will only trigger once Quick Thinking runs out of energy to drain."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "If the player would take enough damage to lose both all their health and energy, the player will instead enter bleedout immediately and not lose any energy."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "Will not work on Hildryn or Lavos since they do not have energy capacity."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Quick Thinking",
                  "pageId": 196118,
                  "revisionId": 2790168,
                  "section": "Notes",
                  "excerpt": "Rage and Hunter Adrenaline will not replenish energy if a portion of health is lost during a Magnetic proc."
                }
              },
