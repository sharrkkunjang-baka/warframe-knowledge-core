          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "Allows for the pickup of orbs while the associated resource pool is full, for the purpose of conversion. For example, if Health is full but Energy is not, a Health Orb will be picked up and converted to energy."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "The final converted restoration is rounded down. For example, with a rank 10 Equilibrium, collecting a small Energy Orb worth 25 Energy will restore 27 Health, rather than 27.5 Health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "Health converted from Energy Orbs will not heal Companions ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "The effects of Arcane Energize and Energy Pulse do not apply to energy from converted health orbs. Likewise, Arcane Pulse does not apply to health from converted energy orbs."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "Increased Health and/or Energy Orb Effectiveness from Amber Archon Shard , Restorative Bond , or Dagath 's Passive is not taken into account and will only use the orb's base values."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "As of Hotfix 13.9.3.1 (2014-07-11), Equilibrium can be acquired from Mod Packs and Transmutation ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "Equilibrium stacks with Equinox 's passive ability, which converts 10% of Health Orbs into Energy and vice versa, up to a total of 120% efficiency."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "This effect is additive with the Violet Archon Shard bonus of Health pickups give +20% (+30%) Energy. Energy pickups give +20% (+30%) Health."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Equilibrium",
                  "pageId": 179823,
                  "revisionId": 2790182,
                  "section": "Notes",
                  "excerpt": "Equilibrium (and Violet Archon Shards, by extension) does work with Universal Orbs , adding a bonus replenishment of Health and Energy."
                }
              }
