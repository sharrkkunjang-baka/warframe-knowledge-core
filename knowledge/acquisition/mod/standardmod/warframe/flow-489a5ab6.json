          "evidence": [],
          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Flow",
                  "pageId": 18231,
                  "revisionId": 2677185,
                  "section": "Notes",
                  "excerpt": "The energy increase is applied to the base energy reserve of a Warframe after energy gains from Rank Bonuses are applied, but before flat bonuses such as Arcane Battery or Azure Archon Shards ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Flow",
                  "pageId": 18231,
                  "revisionId": 2677185,
                  "section": "Notes",
                  "excerpt": "Energy t o t a l = ( Energy b a s e + Rank Bonuses ) × ( 1 + Flow Multiplier ) + Flat Bonuses"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Flow",
                  "pageId": 18231,
                  "revisionId": 2677185,
                  "section": "Notes",
                  "excerpt": "Example: A rank 0 Loki has an energy pool of 175. When equipped with a max rank Flow , the Warframe would have 175 × (1 + 100% ) = 350 maximum energy."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Flow",
                  "pageId": 18231,
                  "revisionId": 2677185,
                  "section": "Notes",
                  "excerpt": "A rank 30 Loki has a base energy pool of 175, plus 50 from rank bonuses, for a total of 225 base energy. When equipped with a max rank Flow , the Warframe would have (175 + 50) × (1 + 100% ) = 450 maximum energy."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Flow",
                  "pageId": 18231,
                  "revisionId": 2677185,
                  "section": "Notes",
                  "excerpt": "This mod is better than Streamline mod for some purposes."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Flow",
                  "pageId": 18231,
                  "revisionId": 2677185,
                  "section": "Notes",
                  "excerpt": "Due to a higher energy pool, abilities can be cast more often. The additional energy allows for more uses than the reduced usage of Streamline."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Flow",
                  "pageId": 18231,
                  "revisionId": 2677185,
                  "section": "Notes",
                  "excerpt": "The additional energy benefits certain mods (such as Quick Thinking and Rage )."
                }
              },
              {
                "reviewStatus": "draft",
