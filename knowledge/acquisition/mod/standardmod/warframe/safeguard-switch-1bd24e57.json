          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Invulnerability period is affected by Ability Duration mods. Duration can be refreshed while active. Can affect multiple allies simultaneously. There is no cooldown to re-cast the ability."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Loki is only granted the invincibility if he swaps position with an enemy ; swapping positions with an ally only clears status effects while giving the ally increased invincibility."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Casting range is affected by Range mods."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Casting time is affected by Casting Speed mods."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Works on other players, companions, allied NPCs, and Loki's own Decoy ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Loki must cast the ability either on an enemy, an enemy corpse, or even an enemy as it's in its death animation in order to receive the invulnerability."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Can be cast on some bosses like The Jackal but not on Archons. Can also be cast on Demolysts/Demolishers, Acolytes, Liches, etc including on Eximus units with their Overguard up."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "The invulnerability period is only granted to Loki upon completion of the teleport. So then if Loki receives fatal damage before the animation is complete, Loki will still teleport with the target but then will immediately be downed/killed. This can happen either through receiving fatal damage directly during the first portion of the animation (as Loki begins to teleport) or via a status proc where the tick delivers fatal damage during the teleport animation. Therefore increasing Loki's casting speed will reduce this window of opportunity for him to receive fatal damage if his shields are down."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Cleanses status effects and provides immunity to newly acquired status procs as they tick whilst the invulnerability period is active."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "If the invulnerability duration expires while there's still status procs active, then those procs will do damage on the remaining ticks."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Provides immunity to stagger and knockdown."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Provides immunity to Acolyte, Lich & Eximus abilities including energy drain clouds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "The visual FX of energy drain clouds will still play on the screen, however Loki's energy pool will remain unaffected."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "The invulnerability period will not be nullified by Demolyst/Demolisher pulses, nor from walking inside of Nullifier bubbles."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "This is because the ability grants Loki invulnerability similar to Rolling Guard or mission spawn invulnerability, instead of the ability remaining 'in effect' or 'active' where it is susceptible to being nullified."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Loki still cannot cast abilities during the range of an active pulse or from inside of Nullifier bubbles however."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Will proc Arcane Avenger as Loki is still being 'hit' but takes no damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard Switch",
                  "pageId": 571869,
                  "revisionId": 2729755,
                  "section": "Notes",
                  "excerpt": "Allows Loki an easy way to maintain overshields which is useful for activating Cascadia Overcharge."
                }
              }
