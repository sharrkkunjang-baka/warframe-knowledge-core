                "provenance": {
                  "pageTitle": "Rage",
                  "pageId": 56485,
                  "revisionId": 2749573,
                  "section": "Notes",
                  "excerpt": "Laser traps encountered in the Orokin Void and Orokin Derelicts ."
                }
              },
              {
