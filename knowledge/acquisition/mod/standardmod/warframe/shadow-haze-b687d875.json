          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Critical chance bonus is affected by Sevagoth 's Ability Strength ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Critical chance bonus is applied additively after mods, the same way as Arcane Avenger and Covenant ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "For example, a Baza Prime with a rank 5 Point Strike affected by Reap with a rank 5 Intensify will have 28% × (1 + 150%) + (50% × (1 + 30%)) = 135% critical chance."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "The bonus does not apply to radial attacks on weapons such as Ogris ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "The bonus does not work on abilities that are able to land critical hits, like Nova 's Null Star , Wisp 's Breach Surge or Vauban 's Minelayer ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "The bonus will apply to Amps ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Shadow Haze can only be equipped on Sevagoth himself, but grants its effects to Sevagoth's Shadow via its Death's Harvest ability."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "The critical chance bonus would still be determined by the Ability Strength of Sevagoth ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "The flying lifespan and area of effect's radius of shadows spawned by Death's Harvest are determined by the Ability Duration and Ability Range of Sevagoth , while the Damage Vulnerability of Death's Harvest applied by the shadows are determined by the Ability Strength and Ability Duration of Sevagoth's Shadow ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Number of Shadows is not affected by Mods ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Spawned Shadows take flight toward the direction their enemy host was facing and travel at the regular flight speed of Reap 's tap-cast. They can traverse across high and low terrain elevations as invulnerable flying entities."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "They auto-lock to the closest enemy yet unaffected by Reap or Death's Harvest, within a 30 meters detection range around each Shadow."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Considered new instances of Reap."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Each Shadow inflicts its Radiation damage, marks enemies with Death's Harvest debuff, as well as trigger ability synergy with his Death Well passive and Sow . Multiple spawned Shadows can damage enemies affected by previous Shadows."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Shadow Haze",
                  "pageId": 1580215,
                  "revisionId": 2772522,
                  "section": "Notes",
                  "excerpt": "Cannot be controlled via Sevagoth player's aiming down sights."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
