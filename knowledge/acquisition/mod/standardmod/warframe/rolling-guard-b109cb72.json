              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "This mod works while in Archwing in Atmospheric mode, provided it is equipped on the active Warframe, and Titania in Razorwing mode. It can be activated by the dash move in all six cardinal directions (forward, back, left, right, up and down)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "This mod allows low durability frames such as Loki , Ember , or Nova to have a small window of invulnerability to cast their abilities in the open."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "Allows Limbo to remain safe while exiting the rift, allowing the player to maintain continuous protection as long as they re-enter the rift before the invincibility duration ends."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "It also synergizes particularly well with Mirage , as she lacks a defense against area-of-effect attacks, and has low durability. In addition, her passive ability letting her roll much more quickly gives her more time to act while invulnerable."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "The invulnerability period will also give her ample time to cast Prism , killing and/or blinding enemies to keep them from attacking after Rolling Guard 's effects end."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "For similar reasons to Mirage 's passive, it also synergizes well with Amalgam Barrel Diffusion , due to its effect of speeding up rolling animations."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "Can be used to avoid getting Magnetic procs from Eidolon 's Energy Spike attacks if rolls are timed correctly."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "It can be used to remove magnetic procs that are already underway, reducing the amount of energy loss from the proc."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "The mod also grants full Knockdown resistance during the invulnerability period."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Rolling Guard",
                  "pageId": 1355610,
                  "revisionId": 2784343,
                  "section": "Notes",
                  "excerpt": "The mod works for Yareli while rolling on Merulina."
                }
              }
