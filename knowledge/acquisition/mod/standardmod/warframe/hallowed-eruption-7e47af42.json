              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hallowed Eruption",
                  "pageId": 608875,
                  "revisionId": 2790945,
                  "section": "Notes",
                  "excerpt": "Without further modding, its maximum damage is [ 20 ⋅ 2 ⋅ ( 1 + 2 ) ] ⋅ 100 = 12 , 000 ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Hallowed Eruption",
                  "pageId": 608875,
                  "revisionId": 2790945,
                  "section": "Notes",
                  "excerpt": "With Intensify , its maximum damage becomes [ 20 ⋅ 2 ⋅ ( 1 + 2 ) ] ⋅ [ 100 ⋅ ( 1 + 0.3 ) ] = 15 , 600 ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
