          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Every half second tick of damage from each Light's Judgment Well has a 5% chance to spawn a Jade Light beam, which lasts for 3 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Overlapping wells can each damage the same target, increasing the likelihood of a beam spawning."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "A maximum of 8 beams can be active at one time (not scaling with strength)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Spawn chance is affected by Ability Strength ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Beam duration is affected by Ability Duration ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "The arsenal only displays the duration rounded to the nearest full second, despite the unrounded number being used for the ability."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "An extra 16.67% duration is needed for each additional tick of damage from the Jade Light beam."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "The first tick of damage is dealt immediately upon the beam being spawned. Additional ticks are dealt at intervals of 0.5 seconds, but delayed by one frame."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Because of this slight delay, reaching an exact multiple of 16.67% duration will not yield an additional tick of damage; a minuscule amount of extra duration is required beyond that. For example, 100% ability duration will give a beam duration of 3s, but a tick of damage will not be dealt at the 3 second mark. With 101% duration however, an additional tick will occur at the 3 second mark, for a total of 7 ticks instead of 6."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "The beam deals 100 Heat damage every half second."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Damage is not affected by Ability Strength."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Base damage is effectively 150 due to Light's Judgment's inherent 50% damage vulnerability."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Total beam damage doubles after every hit, causing the damage to exponentially increase over time."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Every tick of damage has a 100% heat status chance (not scaling with strength). The damage of each new heat proc scales with the beam's current damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Just like Jade Light beams from the Jade Eximus , the satellite orb that shoots the beam is destructible. Enemies will not target the orb, however stray enemy bullets can hit the orb and deactivate the beam, as can Nullifier bubbles touching the orb."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Unlike the Jade Eximus, the beams from this augment do not follow behind the target at a fixed speed. Instead, they stay attached to enemies regardless of how quickly they move. The beam will even follow teleporting enemies such as the Flameblade ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "Due to the exponential growth of the beam's damage, focusing on duration can lead to higher damage values. Strength shouldn't be completely ignored however, as it is still important for increasing the beam spawn chance."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Jade's Judgment",
                  "pageId": 1598992,
                  "revisionId": 2790315,
                  "section": "Notes",
                  "excerpt": "The beams take on Jade's primary energy color, however, client players will always see the default light green of Jade Light beams (including for Jade herself if she is not host)."
                }
              }
            ],
