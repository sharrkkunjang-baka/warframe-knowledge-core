          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "This augment allows Warding Halo to be cast on allied Warframes, Companions , Eidolon Lures , summoned allied units such as Specters , allied Invasion units, Hostages , Kavor Defectors , Sortie and Arbitrations Defense Operatives."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "The modified Warding Halo only takes into account Nezha's Armor value and Ability Strength at the time of casting, which in turn can be affected by Arcane Enhancements , abilities like Metronome and Power of The Seven , and mods such as Health Conversion or Growing Power ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "Multiple instances can be active simultaneously."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "Remaining durability on players can be seen next to the squad UI, however there is no way of knowing the health of rings cast on other units."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "Just like Safeguard's health, the absorbed damage that can be stacked up in the first 3 seconds is halved, either directly from enemies or environmental hazards"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "The \"effectiveness\" in the augment's description refers only to the Warding Halo's health. Allies still receive the full 90% Damage Reduction while Warding Halo is active on them."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "Casting Warding Halo on friendly units has no range limit but requires line of sight."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "Players under the effects of Safeguard will use the visual effects associated with Warding Halo, using the energy color of the Nezha who cast it."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "Warding Halo does not get removed from allies when the Nezha who cast it goes inside a Nullifier field ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Safeguard",
                  "pageId": 1039547,
                  "revisionId": 2655067,
                  "section": "Notes",
                  "excerpt": "Going out of bounds and resetting will remove Warding Halo from players but will not remove it from Companions."
                }
              }
            ],
