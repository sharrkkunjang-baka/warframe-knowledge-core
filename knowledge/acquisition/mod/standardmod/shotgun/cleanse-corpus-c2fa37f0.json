              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Cleanse Corpus",
                  "pageId": 113189,
                  "revisionId": 2687261,
                  "section": "Notes",
                  "excerpt": "Despite being listed as a multiplier, it will stack additively with other sources of Damage to Corpus."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Cleanse Corpus",
                  "pageId": 113189,
                  "revisionId": 2687261,
                  "section": "Notes",
                  "excerpt": "For example, if you had a Riven Mod with x0.5 Damage to Corpus and a max rank Cleanse Corpus with x1.3 Damage to Corpus, you would have a 1 - 0.5 + 0.3 = x0.8 multiplier for damage against Corpus with both mods equipped."
                }
              }
