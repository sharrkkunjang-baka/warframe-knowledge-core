          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lingering Torment",
                  "pageId": 571763,
                  "revisionId": 2621084,
                  "section": "Notes",
                  "excerpt": "The mod's effects are only visible on Status Effects with an associated duration, either increasing the duration of the associated debuff ( Puncture , Cold , Corrosive , Magnetic , Radiation , and Viral ), or the number of ticks associated with DoT effects ( Slash , Electricity , Toxin , Gas , and Heat )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lingering Torment",
                  "pageId": 571763,
                  "revisionId": 2621084,
                  "section": "Notes",
                  "excerpt": "This mod will not affect the duration of crowd control effects generated by Status Effects (staggers from Impact and the panic duration of Heat )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lingering Torment",
                  "pageId": 571763,
                  "revisionId": 2621084,
                  "section": "Notes",
                  "excerpt": "However, it does affect the duration of the freeze effect applied by Cold after reaching 10 stacks."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lingering Torment",
                  "pageId": 571763,
                  "revisionId": 2621084,
                  "section": "Notes",
                  "excerpt": "Increased Status Duration will slow down the Armor Strip effect of Heat . For example, with +100% status duration, the armor strip will occur every second instead of every half second. As a result, the full 50% armor strip will only be achieved after 4 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Lingering Torment",
                  "pageId": 571763,
                  "revisionId": 2621084,
                  "section": "Notes",
                  "excerpt": "Status Effects from the radial blasts of Syndicate Weapon Augments and Syndicate Weapons are not affected by this mod."
                }
              }
            ],
