            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Magazine Extension",
                  "pageId": 572287,
                  "revisionId": 2606864,
                  "section": "Notes",
                  "excerpt": "For any non-integer magazine values the magazine size is simply rounded to the nearest whole number. For example, a Dual Decurion modded with a max rank Magazine Extension will have a calculated magazine size of 32 × (1 + 60%) = 51.2 , which will simply round to 51 ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Magazine Extension",
                  "pageId": 572287,
                  "revisionId": 2606864,
                  "section": "Notes",
                  "excerpt": "All Archguns use their entire ammunition reserve as the magazine that regenerates over time, thus acting as both an increase in magazine capacity as well as maximum ammunition capacity."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Magazine Extension",
                  "pageId": 572287,
                  "revisionId": 2606864,
                  "section": "Notes",
                  "excerpt": "Does not increase reload rate. Due to this, unlike magazine capacity mods for non-Archwing weapons, Magazine Extension does not increase sustained DPS."
                }
              }
            ],
