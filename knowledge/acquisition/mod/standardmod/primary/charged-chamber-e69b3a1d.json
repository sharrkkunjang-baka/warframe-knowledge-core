          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Charged Chamber",
                  "pageId": 114297,
                  "revisionId": 2667821,
                  "section": "Notes",
                  "excerpt": "Charged Chamber is multiplicative with other damage mods. For example, a Vectis installed with a max ranked Charged Chamber and Serration will deal 225 × (1 + 165%) × (1 + 40%) = 834.75 damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Charged Chamber",
                  "pageId": 114297,
                  "revisionId": 2667821,
                  "section": "Notes",
                  "excerpt": "Stacks additively with Primed Chamber for up to 140% bonus damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Charged Chamber",
                  "pageId": 114297,
                  "revisionId": 2667821,
                  "section": "Notes",
                  "excerpt": "Charged Chamber does not work with Sentinel weapons (you can fit it but there is no bonus damage)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Charged Chamber",
                  "pageId": 114297,
                  "revisionId": 2667821,
                  "section": "Notes",
                  "excerpt": "If used with Ammo Efficiency bonuses, it will provide bonus damage to a shot as long as the magazine counter is at Max Magazine − 1 after a shot is fired."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Charged Chamber",
                  "pageId": 114297,
                  "revisionId": 2667821,
                  "section": "Notes",
                  "excerpt": "For example, a Vulkar with Energized Munitions will have the 4th, 5th, 6th, and 7th shots buffed by Charged Chamber as the magazine counter is at 6 - 1 = 5 during those shots."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Charged Chamber",
                  "pageId": 114297,
                  "revisionId": 2667821,
                  "section": "Notes",
                  "excerpt": "When used alongside 100% ammo efficiency, make sure one shot is missing from the magazine, since the buff doesn't apply on a completely full one."
                }
              }
            ],
