          "evidence": [],
          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Internal Bleeding",
                  "pageId": 1545022,
                  "revisionId": 2770554,
                  "section": "Notes",
                  "excerpt": "Cannot produce multiple procs in a single instance of damage alongside any other Slash sources, such as a weapon's innate Slash , Hunter Munitions , or the debuff from Seeking Talons ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Internal Bleeding",
                  "pageId": 1545022,
                  "revisionId": 2770554,
                  "section": "Notes",
                  "excerpt": "Procs of Hunter Munitions and Internal Bleeding are drawn independently, and if both proc at the same time, only 1 slash proc is applied. With both mods, if a shot both crits and applies impact status, the probability of Slash proc is 54.5% (with attack speed >= 2.5) or 79% (with attack speed < 2.5)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Internal Bleeding",
                  "pageId": 1545022,
                  "revisionId": 2770554,
                  "section": "Notes",
                  "excerpt": "Proccing impact more than once in a single instance of damage will not allow this mod to proc more than once, nor will it increase the chance of the mod proccing."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Internal Bleeding",
                  "pageId": 1545022,
                  "revisionId": 2770554,
                  "section": "Notes",
                  "excerpt": "Hard Engage works with this mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Internal Bleeding",
                  "pageId": 1545022,
                  "revisionId": 2770554,
                  "section": "Notes",
                  "excerpt": "Fire Rate buffs such as Gauss ' Redline , Wisp ' Haste Reservoirs and Arcane Acceleration can negatively impact this mod's performance since it may increase the weapon's fire rate past 2.5."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Internal Bleeding",
                  "pageId": 1545022,
                  "revisionId": 2770554,
                  "section": "Notes",
                  "excerpt": "If the weapon's fire rate is exactly 2.5 it won't count towards the 70% chance."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Internal Bleeding",
                  "pageId": 1545022,
                  "revisionId": 2770554,
                  "section": "Notes",
                  "excerpt": "For bows, the threshold is still depending of the Fire Rate, even if it is an hidden stat. Most bows have an unmodded Fire Rate of 1, except : Cinta with 1.5 Fire Rate, and Kuva Bramma and Nataruk with 0.667 Fire Rate."
                }
              }
            ],
