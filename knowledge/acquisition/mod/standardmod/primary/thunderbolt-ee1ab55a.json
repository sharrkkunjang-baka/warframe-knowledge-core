          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "The explosion deals 250 Blast damage to the target, as well as to nearby enemies within 10 meters of the blast."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "The explosion inflicts self-stagger ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "Unlike the area blasts of dedicated blast weapons like Launchers, Thunderbolt does NOT have a safety distance to prevent self-stagger. Furthermore, if the shot hits and explodes close enough to you it will do a full Knockdown instead of just a self-stagger."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "The explosive damage from this mod cannot be increased with base damage, such as Serration , and elemental mods such as Hellfire , but it will be increased by Bane mods, like Bane of Infested ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "Compared to Launchers, the Thunderbolt blast has full Punch Through (like most Launchers) and zero falloff throughout its entire area of effect (unlike most Launchers), so all enemies take full damage even at the outer-most edges of the blast while behind cover."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "The blast area is increased by Firestorm or Primed Firestorm ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "The explosions are silent."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "Arrows fired at terrain and other surfaces still explode, but not arrows fired at teammates or other allies."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "When the explosion occurs, the projectile of the arrow causing that is actually \"dissolved\". Thus any subsequent mechanics relating to the projectile will not happen, such as punching through or the spore coming after the arrow of Mutalist Cernos ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "Cannot be equipped on Lenz ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "Can be paired with Cautious Shot to reduce stagger effects."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Thunderbolt",
                  "pageId": 36917,
                  "revisionId": 2739044,
                  "section": "Notes",
                  "excerpt": "The explosion will trigger effects that activate upon damaging enemies; for example, the Thunderbolt explosion created from an Evensong 's projectile will apply Puncture status effects to each enemy it hits."
                }
              }
            ],
