          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Unlike most other galvanized mods, Galvanized Scope stacks each have their own duration. The duration doesn't pause after you gain more stacks, so you will lose them before the visual timer on the HUD runs out."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Only kills from a weapon equipped with this mod will give stacks, and only the weapon equipped with this mod will benefit from the buff. If equipped on both a normal weapon and an Exalted Weapon , this mod will affect both weapons."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Can be activated by Pax Seeker 's projectiles."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Most status procs target center-mass and cannot trigger the critical chance bonus or the on kill effect."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Electricity and Gas procs are able to trigger both effects when aimed at the head however, as they are able to land headshots themselves."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Given that Galvanized Scope is an upgraded version of Argon Scope , the caveats of the latter still apply, namely:"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "This section is transcluded from Argon Scope § Notes . To change it, please edit the transcluded page ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Argon Scope is additive with similar mods. For example, a Snipetron with a max rank Argon Scope and Point Strike will have a 30% × (1 + 135% + 150%) = 115.5% critical chance ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Argon Scope will trigger upon headshots, i.e. any weapon hit to an enemy's head, whether the target survives or not."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Headshots will refresh Argon Scope's timer."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "The headshot that triggers Argon Scope will not benefit from the buff itself (unless the buff was already active)."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Only hitting the head body part counts as headshot . Hitting other weak spots (such as Moa's backpacks) does not give the buff."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "When using a projectile weapon such as bows , you must continue aiming until the projectile has hit its target to benefit from the buff."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "If activated, Argon Scope will display an icon timer beside the player's health UI, and the Warframe will be briefly surrounded by a flashing energy ribbon."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "This icon is the same as Hydraulic Crosshairs and Cat's Eye and features the four-leaf clover."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Galvanized Scope",
                  "pageId": 1549349,
                  "revisionId": 2654940,
                  "section": "Notes",
                  "excerpt": "Can be installed alongside Point Strike or Critical Delay in order to further increase the critical chance ."
                }
              }
