          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "The Explosion does 600 Blast damage in an 18m radius at max rank, with 0% Status Chance and 100% falloff."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Explosion requires Line of Sight , and it's range is not affected by ( Primed ) Firestorm ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Can break crates."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Can trigger Enkaus 's instakill effect."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Can damage Arbitration Shield Drone s and make them explode on death."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Explosion damage can only be increased by Faction Damage Bonus (e.g. Bane of Infested , Roar ), Extra Hit abilities (e.g. Resupply ), or Damage Vulnerability on enemies (e.g. Molecular Prime )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Can hit Sonar weakpoints."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Can pop Spores when used with Toxic Lash ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Enemies killed by spread forced Extra Hit procs will explode and spread them again."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Combustion Beam is only usable on primary Continuous Weapons . This includes Robotic Weapons like Artax , Cryotra , and Verglas ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "A notable exception to this rule is the Tenet Flux Rifle , because it was derived from continuous weapon ( Flux Rifle ), even though its firing mechanics are similar to an automatic rifle."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Because the Panthera 's secondary fire has a continuous and fixed range, Combustion Beam can also be equipped on it. Enemies killed by either the primary or secondary fire will trigger the explosion."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Torid Incarnon Genesis is still considered just Torid , and cannot equip this mod despite having a beam fire mode."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Combustion beam essentially functions as a weaker Molecular Prime (chain reaction effect), making it effective at clearing weak low level enemies very rapidly."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Combustion Beam",
                  "pageId": 774173,
                  "revisionId": 2780690,
                  "section": "Notes",
                  "excerpt": "Enemies killed in one instant or vaporized on death (e.g. Volatile Runner ) will not trigger the explosion."
                }
              }
            ],
