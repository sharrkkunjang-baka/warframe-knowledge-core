          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "Overall damage will increase, though two parts of the damage still remain. As an example, an unmodified Secura Penta equipped with nothing but Napalm Grenades will deal 325 Heat area of effect damage, as well as 325 Heat direct impact damage. If either procs, the enemy will be dealt procs equal to 162 Heat damage."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "In addition, direct impacts will create a separate 100 Heat which procs, likely there only to guarantee that enemies hit directly will be set on fire."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "Cannot be used with Tether Grenades ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "The fire patches generated by this mod last about 5 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "When installed, Penta's grenades are changed to detonate on contact while still maintaining the manual detonation function with Alternate Fire allowing mid-air detonation and possible headshots on humanoid targets, also resulting in fire patches spawning mid-air."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "Adhesive Blast can be installed to prevent grenades from detonating on contact by making them stick to the object that they make contact with in which they can be manually detonated or will auto-detonate about 5 seconds after attachment."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "Unlike similar weapons such as Torid , Pox , Mutalist Cernos and Ogris with Nightwatch Napalm , the fire patches generated by this mod do not deal direct damage, but instead proc Heat status effect when enemies enter the effect radius. This deals very little damage regardless of the mods on the weapon, but causes enemies to flail around. This effect works on the player as well. The Heat status effect is not affected by status duration mods."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "When used with Mirage 's Hall of Mirrors , it will create extra patches of fire."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "The fire-patch of the user will cause Heat damage while the clone's fire-patches are only visual and will not damage anything."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "Unlike Nightwatch Napalm , the small fire patches range cannot be increased further, restricting the crowd control benefits of the bonus Heat ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Napalm Grenades",
                  "pageId": 1396633,
                  "revisionId": 2789386,
                  "section": "Notes",
                  "excerpt": "When modded to create Gas or Radiation , direct hits and the patches will still deal Heat damage and status effects, though this is just for utility or crowd control as they will deal very low damage."
                }
              }
