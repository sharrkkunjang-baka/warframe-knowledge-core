            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "Equipping this mod will set weapon's Multishot to its default ignoring other bonuses, even negative effects (e.g. Rifle Riven Mod )."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "The Weak Point Damage is additive with the Weak Point Multiplier on enemies."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "The values described on the mod are misleading, the actual damage bonus being 1.5x of the listed value."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "For example, a typical humanoid enemy such as a Butcher has a 3x Weak Point Multiplier on its head. A rank 10 Acuity will increase this value to 3 + (3.5 * 1.5) = 8.25x"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "This is a relative damage increase of +175%"
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "MOA 's backpack is one exception to this, accurately adding the listed damage bonus to its Weak Point Multiplier ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "Note that damage increase may vary between different types of enemies, since not all enemies will receive \"Headcrit\" damage, for example MOA and Lumbering Fragment ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "Weapons with Area of Effect damage or other special projectiles that inherently do not deal increased weakpoint damage will not gain increased damage from this mod."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "The Weak Point Damage is multiplicative with bonuses to Headshot Multiplier, such as from Primary Deadhead ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "For example, equipping both Primary Acuity and Primary Deadhead and hitting a 3x weakpoint yields a 1.3*(3+(3.5*1.5))=10.725x multiplier."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "The bonus Critical Chance stacks additively with other mods like Point Strike ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Primary Acuity",
                  "pageId": 1589153,
                  "revisionId": 2789466,
                  "section": "Notes",
                  "excerpt": "Weakspots created by Banshee 's Sonar and Citrine 's Crystallize do not count as weak points."
                }
              }
