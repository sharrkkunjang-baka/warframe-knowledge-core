            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "Drifting Contact is additive with similar mods. For example, a Galatine with a max rank Drifting Contact and Melee Prowess will have a 20% × (1 + 40% + 90%) = 46% status chance ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "Obtained from medium Nightmare Missions, which can be found on Phobos, Jupiter, Saturn, Void, Lua, Europa, Ceres and Kuva Fortress."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "At max rank, Drifting Contact increases the total melee combo counter time to 15 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "Combined with Body Count and Gladiator Rush , the counter time is increased to 33 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "With \"Power Spike\" (Naramon Focus node) the Melee Combo Counter decreases by a certain amount (at Rank 1, 20) each time that the Counter would run out. So, with a maxed Drifting Contact, it decreases the Counter every 15 seconds. Without mods, the Counter gets decreased every 5 seconds."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "Can be stacked with Melee Prowess , Volcanic Edge , Vicious Frost , Voltaic Strike and Virulent Scourge for a total of 295% increase in Status Chance. On weapons with at least 26% base Status Chance, this allows them to achieve a total Status Chance value of 100%, allowing every strike to deal Status Effect proc. On weapons with 27% base Status Chance Melee Prowess is no longer needed to achieve the 100% Status Chance value."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "Weeping Wounds can further increase the Status Chance depending on the Melee Combo Counter."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Drifting Contact",
                  "pageId": 1069421,
                  "revisionId": 2719984,
                  "section": "Notes",
                  "excerpt": "Works well with other mods affecting Melee Combos like Weeping Wounds , Body Count , Gladiator Rush , Blood Rush , Rising Storm and Surging Dash ."
                }
              }
