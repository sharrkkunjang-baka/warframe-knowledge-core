          "mechanicsEvidence": {
            "status": "draft",
            "notes": [
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Can also be equipped on the Latron Wraith and the Latron Prime ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Cannot be equipped simultaneously with Hydraulic Gauge , Loose Hatch or Maximum Capacity ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Consecutive hits on enemies increase the damage bonus by 20%, stacking 20 times up to a maximum of +400% bonus damage. The buff lasts for 2 seconds or if the next shot does not hit an enemy, after which all stacks are removed."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Hitting objects such as Zephyr 's Tornado , Nullifier Crewman 's bubble, or an Arctic Eximus ' globe are counted as a 'miss' and will reset the damage bonus."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Multiplicatively stacks with damage bonuses like Serration and Faction Damage Bonus ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Additional hits caused by punch through or Multishot will allow each bullet to trigger multiple stacks. When a shot hits at least one enemy it will not reset the bonus."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Each direct hit from Latron Incarnon Genesis and its ricochets will stack the buff. If the projectile hits a wall before hitting an enemy, it will count as a miss and the damage bonus will reset."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "The bonus is applied on hit to all pellets as damage * 20% * (hits - 1), meaning without multishot, the bonus isn't applied until the second hit. With multishot, not only does the bonus ramp up faster, but also some of the post hit bonus is applied to the hit. For example, with a modded multishot of 3, the first trigger pull would do +40% bonus damage, the second +100%, the third +160%, and so on."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "pageTitle": "Double Tap",
                  "pageId": 841266,
                  "revisionId": 2673619,
                  "section": "Notes",
                  "excerpt": "Bullet attraction bubbles such as Magnetize or Void status will cause each hit to count twice."
                }
              }
            ],
