              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tactical Reload",
                  "pageId": 692374,
                  "revisionId": 2644164,
                  "section": "Notes",
                  "excerpt": "This mod reloads a portion of your weapon's magazine every second. It will not replenish a weapon's total ammo pool, and will partially reload the magazine if there is less than a full mag of ammo in the weapon's total pool."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tactical Reload",
                  "pageId": 692374,
                  "revisionId": 2644164,
                  "section": "Notes",
                  "excerpt": "This mod will take effect when using quick melee, as this counts as holstering the weapon. A great strategy is to quick melee when your magazine gets low and do a few parkour moves to avoid enemies. By the time you finish, a large amount of your clip will be reloaded."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tactical Reload",
                  "pageId": 692374,
                  "revisionId": 2644164,
                  "section": "Notes",
                  "excerpt": "This mod can be equipped to spearguns to further enhance their innate ability to reload the magazine while holstered, boosting the total to 53%."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tactical Reload",
                  "pageId": 692374,
                  "revisionId": 2644164,
                  "section": "Notes",
                  "excerpt": "Bonus stacks additively with the Synth mod set bonus ."
                }
              },
              {
                "reviewStatus": "draft",
                "provenance": {
                  "source": "local-wiki-sqlite",
                  "pageTitle": "Tactical Reload",
                  "pageId": 692374,
                  "revisionId": 2644164,
                  "section": "Notes",
                  "excerpt": "Weapons with a large magazine size, such as Quellor, can benefit greatly from this mod, especially if they have a long reload time."
                }
              }
