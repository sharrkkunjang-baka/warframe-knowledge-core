[{"id":"knowledge.trade.rmt","kind":"knowledge","title":"RMT 是什么","aliases":["RMT","rmt是什么","人民币交易"],"content":"RMT 指现实货币交易，包括有偿代练、带刷等，存在严重封禁风险。","sources":[{"url":"https://www.warframe.com/terms","label":"Warframe Terms"}],"gameVersion":"current","updatedAt":"2026-07-13","reviewStatus":"approved","reviewedBy":["12407"]},{"id":"knowledge.trade.black-platinum","kind":"knowledge","title":"黑金是什么","aliases":["黑金","黑金是什么","负白金"],"content":"黑金通常指通过盗刷、退款欺诈等方式获得的白金，异常交易应联系官方支持。","sources":[{"url":"https://support.warframe.com/","label":"Warframe Support"}],"gameVersion":"current","updatedAt":"2026-07-13","reviewStatus":"approved","reviewedBy":["12407"]}]
