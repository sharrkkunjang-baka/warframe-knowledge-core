{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sharrkkunjang-baka/warframe-knowledge-core/schema/entry.schema.json",
  "title": "Warframe knowledge entry",
  "type": "object",
  "required": ["id", "title", "sources", "gameVersion", "updatedAt", "reviewStatus", "reviewedBy"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "content": { "type": "string", "minLength": 1 },
    "sources": { "type": "array", "items": { "type": "object", "required": ["url", "label"], "properties": { "url": { "type": "string", "format": "uri" }, "label": { "type": "string" } } },
    "gameVersion": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date" },
    "reviewStatus": { "enum": ["draft", "review", "approved", "rejected"] },
    "acquisitionStatus": { "enum": ["stub", "partial", "complete"] },
    "reviewedBy": { "type": "array", "items": { "type": "string" } },
    "kind": { "enum": ["fact", "knowledge"] },
    "module": { "enum": ["acquisition", "gameplay"] },
    "subject": {
      "type": "object",
      "required": ["canonical", "displayName", "category"],
      "properties": {
        "canonical": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "category": { "enum": ["frame", "weapon", "mod", "resource", "companion", "arcane", "other"], "description": "对象的基础类型" },
        "categoryRefs": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }, "uniqueItems": true, "description": "引用 knowledge/categories/<id>.json，可同时属于多个细分类" },
        "officialUniqueName": { "type": "string", "minLength": 1 },
        "setFamily": { "type": "string", "minLength": 1 },
        "pvpKind": { "enum": ["pool", "augment"] },
        "pvpSlot": { "type": "string", "minLength": 1 },
        "conclaveTier": { "type": "string", "minLength": 1 }
      }
    },
    "maxRank": { "type": "integer", "minimum": 0 },
    "rewardTier": { "enum": ["A", "B", "C"], "description": "对象所属的 A/B/C 奖励梯级" },
    "officialUniqueName": { "type": "string", "minLength": 1 },
    "setFamily": { "type": "string", "minLength": 1 },
    "pvpKind": { "enum": ["pool", "augment"] },
    "pvpSlot": { "type": "string", "minLength": 1 },
    "conclaveTier": { "type": "string", "minLength": 1 },
    "tradable": { "type": "boolean" },
    "rarity": { "type": ["string", "null"] },
    "polarity": { "type": ["string", "null"] },
    "generator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "arcaneType": { "type": ["string", "null"] },
    "equipmentClass": { "type": ["string", "null"] },
    "levelStats": { "type": "array" },
    "arcaneAcquisition": {
      "type": "object",
      "required": ["generated", "manual"],
      "properties": {
        "generated": { "type": "object", "required": ["identity", "classification", "stats", "acquisition"] },
        "manual": { "type": "object", "required": ["aliases", "methods", "methodRefs", "notes", "overrides", "reviewStatus", "reviewedBy"] }
      }
    },
    "modAcquisition": {
      "type": "object",
      "required": ["generated", "manual"],
      "properties": {
        "generated": {
          "type": "object",
          "required": ["identity", "wiki"],
          "properties": {
            "identity": { "type": "object" },
            "wiki": {
              "type": ["object", "null"],
              "properties": {
                "methods": { "type": "array" },
                "evidence": { "type": "array" },
                "mechanicsEvidence": { "type": "object" },
                "unresolvedEntities": { "type": "array" },
                "status": { "enum": ["complete", "partial", "unresolved"] }
              }
            }
          }
        },
        "manual": {
          "type": "object",
          "required": ["methods", "methodRefs", "overrides", "reviewStatus", "reviewedBy"],
          "properties": {
            "methods": { "type": "array" },
            "methodRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
            "overrides": { "type": "object" },
            "reviewStatus": { "enum": ["draft", "review", "approved", "rejected"] },
            "reviewedBy": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "effectDetails": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stat", "displayName", "value", "unit"],
        "properties": {
          "stat": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "displayName": { "type": "string", "minLength": 1 },
          "value": { "type": "number" },
          "unit": { "type": "string" }
        }
      }
    },
    "frameAcquisition": {
      "type": "object",
      "properties": {
        "generated": {
          "type": "object",
          "properties": {
            "routing": {
              "type": "object",
              "required": ["componentCategory", "blueprintCategory", "componentVariables", "blueprintVariables", "blueprintSource"],
              "properties": {
                "componentCategory": { "type": "string", "pattern": "^frame-" },
                "blueprintCategory": { "type": ["string", "null"] },
                "componentVariables": { "type": "object" },
                "blueprintVariables": { "type": "object" },
                "blueprintSource": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "manual": {
          "type": "object",
          "properties": {
            "routingOverride": { "type": "object" },
            "acquisitionText": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "summary": { "type": "string", "minLength": 1 },
    "prerequisites": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "methodRefs": { "type": "array", "items": { "type": "string", "pattern": "^gameplay\\." }, "uniqueItems": true },
    "acquisitionQuery": { "type": "string", "minLength": 1, "description": "允许通过“刷 <值>”直接打开此玩法" },
    "steps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "rewardGroups": {
      "type": "object",
      "propertyNames": { "enum": ["A", "B", "C"] },
      "additionalProperties": {
        "type": "object",
        "required": ["planets"],
        "properties": {
          "planets": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "tags": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": { "properties": { "module": { "const": "acquisition" } }, "required": ["module"] },
      "then": {
        "required": ["subject", "prerequisites", "methodRefs"],
        "anyOf": [
          { "required": ["summary"] },
          { "required": ["content"] },
          { "properties": { "subject": { "required": ["categoryRefs"] } } }
        ]
      }
    },
    {
      "if": { "properties": { "module": { "const": "gameplay" } }, "required": ["module"] },
      "then": { "required": ["aliases", "summary", "content", "steps", "notes"] }
    }
  ],
  "additionalProperties": true
}
