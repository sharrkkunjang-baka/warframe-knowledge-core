    "counts": {"type":"object","required":["input","items","excluded","byKind","excludedByReason"],"properties":{"input":{"type":"integer","minimum":1},"items":{"type":"integer","minimum":1},"excluded":{"type":"integer","minimum":0},"byKind":{"type":"object"},"excludedByReason":{"type":"object","additionalProperties":{"type":"integer","minimum":1}}}},
    "items": {"type":"array","items":{"type":"object","required":["uniqueName","canonical","displayName","kind","semanticKinds","description","tradable","drops","recipes","recipeVariants","buildQuantity","sourceCategory","sourceFile"],"properties":{"uniqueName":{"type":"string","pattern":"^/Lotus/"},"canonical":{"type":"string","minLength":1},"displayName":{"type":"string","minLength":1},"kind":{"enum":["resources","gear","misc","arcanes"]},"semanticKinds":{"type":"array","minItems":1,"items":{"type":"string","minLength":1},"uniqueItems":true},"tradable":{"type":"boolean"},"drops":{"type":"array"},"recipes":{"type":"array"},"recipeVariants":{"type":"array"},"buildQuantity":{"type":"number","minimum":1},"sourceCategory":{"enum":["Resources","Gear","Misc","Arcanes"]},"sourceFile":{"enum":["Resources.json","Gear.json","Misc.json","Arcanes.json"]},"arcaneType":{"type":["string","null"]},"equipmentClass":{"type":["string","null"]},"rarity":{"type":["string","null"]},"levelStats":{"type":"array"},"maxRank":{"type":"integer","minimum":0}}}}
  }
}
